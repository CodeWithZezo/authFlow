{
  "devDependencies": {
    "@types/jest":                 "^29.5.12",
    "@types/supertest":            "^6.0.2",
    "jest":                        "^29.7.0",
    "ts-jest":                     "^29.1.4",
    "supertest":                   "^7.0.0",
    "mongodb-memory-server":       "^10.0.1"
  },
  "scripts": {
    "test":             "jest --config tests/jest.config.ts",
    "test:unit":        "jest --config tests/jest.config.ts --selectProjects unit",
    "test:integration": "jest --config tests/jest.config.ts --selectProjects integration",
    "test:e2e":         "jest --config tests/jest.config.ts --selectProjects e2e",
    "test:coverage":    "jest --config tests/jest.config.ts --coverage",
    "test:watch":       "jest --config tests/jest.config.ts --watch"
  }
}
