#Test environment — all secrets are dummies, MongoDB uses in-memory server
NODE_ENV=test
PORT=5001

#JWT — test-only secrets (short expiry to speed up token tests)
JWT_ACCESS_SECRET=test_access_secret_authflow_jest
JWT_REFRESH_SECRET=test_refresh_secret_authflow_jest

#AWS S3 — mocked in tests, values only need to be non-empty
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test_access_key
AWS_SECRET_ACCESS_KEY=test_secret_key
AWS_S3_BUCKET=test-authflow-bucket

#CORS
CORS_ORIGIN=http://localhost:3000


